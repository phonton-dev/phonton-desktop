{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window — shell, CLI install, phonton serve, deep links",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "deep-link:default",
    "updater:default",
    "process:default",
    "core:window:allow-set-icon",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-show",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "phonton-serve",
          "cmd": "phonton",
          "args": ["serve"],
          "sidecar": false
        },
        {
          "name": "win-phonton-serve",
          "cmd": "cmd",
          "args": ["/c", "phonton", "serve"],
          "sidecar": false
        },
        {
          "name": "win-phonton-serve-resolved",
          "cmd": "cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "unix-phonton-serve-resolved",
          "cmd": "sh",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "phonton-serve",
          "cmd": "phonton",
          "args": ["serve"],
          "sidecar": false
        },
        {
          "name": "win-phonton-serve",
          "cmd": "cmd",
          "args": ["/c", "phonton", "serve"],
          "sidecar": false
        },
        {
          "name": "win-phonton-serve-resolved",
          "cmd": "cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "unix-phonton-serve-resolved",
          "cmd": "sh",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "npm-version",
          "cmd": "npm",
          "args": ["--version"],
          "sidecar": false
        },
        {
          "name": "npm-cmd-version",
          "cmd": "npm.cmd",
          "args": ["--version"],
          "sidecar": false
        },
        {
          "name": "npm-prefix",
          "cmd": "npm",
          "args": ["prefix", "-g"],
          "sidecar": false
        },
        {
          "name": "npm-cmd-prefix",
          "cmd": "npm.cmd",
          "args": ["prefix", "-g"],
          "sidecar": false
        },
        {
          "name": "npm-root",
          "cmd": "npm",
          "args": ["root", "-g"],
          "sidecar": false
        },
        {
          "name": "npm-cmd-root",
          "cmd": "npm.cmd",
          "args": ["root", "-g"],
          "sidecar": false
        },
        {
          "name": "npm-view-phonton",
          "cmd": "npm",
          "args": ["view", "phonton-cli", "version"],
          "sidecar": false
        },
        {
          "name": "npm-cmd-view-phonton",
          "cmd": "npm.cmd",
          "args": ["view", "phonton-cli", "version"],
          "sidecar": false
        },
        {
          "name": "npm-install-phonton",
          "cmd": "npm",
          "args": true,
          "sidecar": false
        },
        {
          "name": "npm-cmd-install-phonton",
          "cmd": "npm.cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "where-phonton",
          "cmd": "where",
          "args": ["phonton"],
          "sidecar": false
        },
        {
          "name": "win-test-phonton-cmd",
          "cmd": "cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "win-phonton-verify",
          "cmd": "cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "win-phonton-run",
          "cmd": "cmd",
          "args": true,
          "sidecar": false
        },
        {
          "name": "unix-phonton-verify",
          "cmd": "sh",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
